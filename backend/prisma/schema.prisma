generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma2"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String       @id @default(uuid())
  username    String       @unique
  email       String       @unique
  password    String
  elo         Int          @default(1200)
  createdAt   DateTime     @default(now())
  submissions Submission[]
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

model Problem {
  id String @id

  title String

  slug String @unique

  difficulty String

  rating Int

  tags Json

  statement String

  inputFormat String

  outputFormat String

  examples Json

  constraints Json

  publicTestCases Json

  hiddenTestCases Json

  timeLimitMs Int @default(1000)

  memoryLimitMb Int @default(256)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
  submissions Submission[]
}

enum SubmissionStatus {
  PENDING
  ACCEPTED
  WRONG_ANSWER
  TIME_LIMIT_EXCEEDED
  MEMORY_LIMIT_EXCEEDED
  RUNTIME_ERROR
  COMPILATION_ERROR
}

enum Language {
  CPP
}

model Submission {
  id        String           @id @default(uuid())
  userId    String
  problemId String
  language  Language
  code      String
  status    SubmissionStatus
  compilerOutput String?
  runtimeOutput String?
  passedTestCases Int @default(0)
  totalTestCases Int @default(0)
  executionTimeMs Int?
  memoryUsedKb Int?
  failureTestCaseIndex Int?
  judgedAt DateTime?
  createdAt DateTime         @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([problemId])
}
