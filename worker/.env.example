DATABASE_URL=postgresql://user:password@host:5432/postgres
REDIS_URL=redis://localhost:6379
SOCKET_URL=http://localhost:5000
WORKER_SECRET=codearena-worker-secret
# Use the compose service name when the worker runs inside Docker.
JUDGE0_BASE_URL=http://judge0-server:2358
JUDGE0_LANGUAGE_ID_CPP=54
JUDGE0_REQUEST_TIMEOUT_MS=15000
JUDGE0_POLL_INTERVAL_MS=500
JUDGE0_MAX_WAIT_MS=120000
JUDGE0_JOB_MAX_ATTEMPTS=3
# Optional, only if your Judge0 instance requires auth.
JUDGE0_AUTH_TOKEN=
