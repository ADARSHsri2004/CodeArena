{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "rootDir": "../",
    "outDir": "./dist",
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "dotenv": ["../backend/node_modules/dotenv"],
      "ioredis": ["../backend/node_modules/ioredis"],
      "@prisma/adapter-pg": ["../backend/node_modules/@prisma/adapter-pg"]
    },
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"],
    "typeRoots": ["./node_modules/@types", "../backend/node_modules/@types"]
  },
  "include": [
    "src/**/*",
    "../backend/src/generated/prisma/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
